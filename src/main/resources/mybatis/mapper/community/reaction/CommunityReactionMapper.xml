<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petcare.petcare.community.reaction.mapper.CommunityReactionMapper">

<!--
  역할: CommunityReactionMapper SQL 정의
  - 박유정 / 2026-07-09

  [좋아요 토글 흐름]
  1. countLikeByPostAndMember — 이미 좋아요 했는지 확인
  2. 있으면 deleteLikeByPostAndMember / 없으면 insertLike
  3. TB_POST.LIKE_CNT 는 CommunityPostMapper 에서 증감

  테이블: TB_POST_LIKE (LIKE_ID, POST_ID, MEMBER_NO, REG_DATE)
  시퀀스: SEQ_TB_POST_LIKE
-->

  <select id="countLikeByPostAndMember" resultType="int">
    SELECT COUNT(*)
    FROM TB_POST_LIKE
    WHERE POST_ID = #{postId}
      AND MEMBER_NO = #{memberNo}
  </select>

  <insert id="insertLike"
          parameterType="com.petcare.petcare.community.reaction.vo.CommunityReactionVO">
    <selectKey keyProperty="likeId" resultType="long" order="BEFORE">
      SELECT SEQ_TB_POST_LIKE.NEXTVAL FROM DUAL
    </selectKey>
    INSERT INTO TB_POST_LIKE (
      LIKE_ID,
      POST_ID,
      MEMBER_NO,
      REG_DATE
    ) VALUES (
      #{likeId},
      #{postId},
      #{memberNo},
      SYSDATE
    )
  </insert>

  <delete id="deleteLikeByPostAndMember">
    DELETE FROM TB_POST_LIKE
    WHERE POST_ID = #{postId}
      AND MEMBER_NO = #{memberNo}
  </delete>

</mapper>
